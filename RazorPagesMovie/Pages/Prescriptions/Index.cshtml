@page
@model RazorPagesMovie.Pages.Prescriptions.IndexModel

@{
    ViewData["Title"] = "Prescriptions";
}

<div class="container mt-4">

    <div class="p-5 mb-4 bg-light rounded-3 border">
        <h1 class="display-5 fw-bold">Prescriptions</h1>
        <p class="fs-5">
            Review saved social prescriptions and track student event recommendations.
        </p>
    </div>

    <p>
        <a asp-page="Create" class="btn btn-primary">Create New Prescription</a>
    </p>

    <div class="row">
        @foreach (var item in Model.Prescription)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-dark">
                    <div class="card-header">
                        <strong>
                            @item.Student.FirstName @item.Student.LastName
                        </strong>
                    </div>

                    <div class="card-body">
                        <p>
                            <strong>Prescriber:</strong>
                            @item.Prescriber.FirstName @item.Prescriber.LastName
                        </p>

                        <p>
                            <strong>Event:</strong>
                            @item.CampusEvent.Title
                        </p>

                        <p>
                            <strong>Date Assigned:</strong>
                            @item.DateAssigned.ToShortDateString()
                        </p>

                        <p>
                            <strong>Status:</strong>
                            @item.Status
                        </p>

                        <p>
                            <strong>Reason:</strong>
                            @item.Reason
                        </p>

                        <p>
                            <strong>Attendance Confirmed:</strong>
                            @item.AttendanceConfirmed
                        </p>

                        <p>
                            <strong>Reminder Sent:</strong>
                            @item.ReminderSent
                        </p>
                    </div>

                    <div class="card-footer">
                        <a asp-page="./Edit" asp-route-id="@item.PrescriptionId" class="btn btn-outline-secondary btn-sm">
                            Edit
                        </a>

                        <a asp-page="./Details" asp-route-id="@item.PrescriptionId" class="btn btn-outline-info btn-sm">
                            Details
                        </a>

                        <a asp-page="./Delete" asp-route-id="@item.PrescriptionId" class="btn btn-outline-danger btn-sm">
                            Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

</div>