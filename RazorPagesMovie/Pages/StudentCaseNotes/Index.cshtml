@page
@model RazorPagesMovie.Pages_StudentCaseNotes.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StudentCaseNote[0].NoteText)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StudentCaseNote[0].CreatedAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StudentCaseNote[0].StudentCase)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StudentCaseNote[0].Prescriber)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.StudentCaseNote) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NoteText)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StudentCase.StudentCaseId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Prescriber.Email)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.StudentCaseNoteId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.StudentCaseNoteId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.StudentCaseNoteId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
