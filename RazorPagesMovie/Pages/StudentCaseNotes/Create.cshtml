@page
@model RazorPagesMovie.Pages.StudentCaseNotes.CreateModel

@{
    ViewData["Title"] = "Create Student Case Note";
}

<h1>Create Student Case Note</h1>

<h4>Student Case Note</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="StudentCaseNote.StudentCaseId" class="control-label">Student Case</label>
                <select asp-for="StudentCaseNote.StudentCaseId" class="form-control" asp-items="ViewBag.StudentCaseId"></select>
            </div>

            <div class="form-group">
                <label asp-for="StudentCaseNote.PrescriberId" class="control-label">Prescriber</label>
                <select asp-for="StudentCaseNote.PrescriberId" class="form-control" asp-items="ViewBag.PrescriberId"></select>
            </div>

            <div class="form-group">
                <label asp-for="StudentCaseNote.NoteText" class="control-label">Notes</label>
                <input asp-for="StudentCaseNote.NoteText" class="form-control" />
                <span asp-validation-for="StudentCaseNote.NoteText" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="StudentCaseNote.CreatedAt" class="control-label">Created Time</label>
                <input asp-for="StudentCaseNote.CreatedAt" class="form-control" />
                <span asp-validation-for="StudentCaseNote.CreatedAt" class="text-danger"></span>
            </div>

            <div class="form-group mt-2">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-2">
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}