@page
@model RazorPagesMovie.Pages.CampusEvents.IndexModel

@{
    ViewData["Title"] = "Campus Events";
}

<h1>Campus Events</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>

<form method="get" class="mb-3">
    <p>
        <label>Category:</label>
        <select asp-for="EventCategory" asp-items="Model.Categories">
            <option value="">All</option>
        </select>

        <label>Title:</label>
        <input type="text" asp-for="SearchString" />

        <input type="submit" value="Filter" class="btn btn-primary btn-sm" />

        <a asp-page="./Index">Back to full list</a>
    </p>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Date</th>
            <th>Time</th>
            <th>Location</th>
            <th>Category</th>
            <th>Source Link</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.CampusEvent) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Title)</td>
            <td>@Html.DisplayFor(modelItem => item.Description)</td>
            <td>@Html.DisplayFor(modelItem => item.EventDate)</td>
            <td>@Html.DisplayFor(modelItem => item.EventTime)</td>
            <td>@Html.DisplayFor(modelItem => item.Location)</td>
            <td>@Html.DisplayFor(modelItem => item.Category)</td>
            <td>@Html.DisplayFor(modelItem => item.SourceLink)</td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.CampusEventId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.CampusEventId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.CampusEventId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>