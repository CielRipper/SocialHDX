@page
@model RazorPagesMovie.Pages.StudentCases.IndexModel

@{
    ViewData["Title"] = "Student Cases";
}

<div class="container mt-4">

    <div class="p-5 mb-4 bg-light rounded-3 border">
        <h1 class="display-5 fw-bold">Student Cases</h1>
        <p class="fs-5">
            Track student support cases connected to students and prescribers.
        </p>
    </div>

    <p>
        <a asp-page="Create" class="btn btn-primary">Create New Student Case</a>
    </p>

    <div class="row">
        @foreach (var item in Model.StudentCase)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-dark">
                    <div class="card-header">
                        <strong>@item.Student.FirstName @item.Student.LastName</strong>
                    </div>

                    <div class="card-body">
                        <p>
                            <strong>Prescriber:</strong>
                            @item.Prescriber.FirstName @item.Prescriber.LastName
                        </p>

                        <p>
                            <strong>Opened Date:</strong>
                            @item.OpenedDate.ToShortDateString()
                        </p>

                        <p>
                            <strong>Case Reason:</strong>
                            @item.CaseReason
                        </p>

                        <p>
                            <strong>Case Status:</strong>
                            @item.CaseStatus
                        </p>
                    </div>

                    <div class="card-footer">
                        <a asp-page="./Edit" asp-route-id="@item.StudentCaseId" class="btn btn-outline-secondary btn-sm">Edit</a>
                        <a asp-page="./Details" asp-route-id="@item.StudentCaseId" class="btn btn-outline-info btn-sm">Details</a>
                        <a asp-page="./Delete" asp-route-id="@item.StudentCaseId" class="btn btn-outline-danger btn-sm">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>

</div>