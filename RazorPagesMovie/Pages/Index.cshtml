@page
@model IndexModel

@{
    ViewData["Title"] = "SocialHDX Dashboard";
}

<div class="container mt-4">

    <div class="p-5 mb-4 bg-light rounded-3 border">
        <h1 class="display-5 fw-bold">SocialHDX Dashboard</h1>
        <p class="fs-5">
            Backend dashboard for managing students, events, prescriptions, and support cases.
        </p>
    </div>

    <div class="row text-center mb-4">
        <div class="col-md-3 mb-3">
            <div class="card h-100 shadow-sm border-dark">
                <div class="card-body">
                    <h5>Students</h5>
                    <h2>@Model.TotalStudents</h2>
                    <a asp-page="/Students/Index" class="btn btn-outline-primary btn-sm">View Students</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card h-100 shadow-sm border-dark">
                <div class="card-body">
                    <h5>Events</h5>
                    <h2>@Model.TotalEvents</h2>
                    <a asp-page="/CampusEvents/Index" class="btn btn-outline-warning btn-sm">View Events</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card h-100 shadow-sm border-dark">
                <div class="card-body">
                    <h5>Prescriptions</h5>
                    <h2>@Model.TotalPrescriptions</h2>
                    <a asp-page="/Prescriptions/Index" class="btn btn-outline-danger btn-sm">View Prescriptions</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card h-100 shadow-sm border-dark">
                <div class="card-body">
                    <h5>Open Cases</h5>
                    <h2>@Model.OpenCases</h2>
                    <a asp-page="/StudentCases/Index" class="btn btn-outline-info btn-sm">View Cases</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-dark">
                <div class="card-header">
                    Recent Prescriptions
                </div>

                <div class="card-body">
                    @if (Model.RecentPrescriptions.Any())
                    {
                        @foreach (var prescription in Model.RecentPrescriptions)
                        {
                            <div class="card mb-3">
                                <div class="card-body">
                                    <h5>
                                        @prescription.Student.FirstName @prescription.Student.LastName
                                    </h5>

                                    <p>
                                        <strong>Event:</strong> @prescription.CampusEvent.Title
                                    </p>

                                    <p>
                                        <strong>Prescriber:</strong>
                                        @prescription.Prescriber.FirstName @prescription.Prescriber.LastName
                                    </p>

                                    <p>
                                        <strong>Status:</strong> @prescription.Status
                                    </p>

                                    <p>
                                        <strong>Date Assigned:</strong>
                                        @prescription.DateAssigned.ToShortDateString()
                                    </p>

                                    <p>
                                        <strong>Reason:</strong> @prescription.Reason
                                    </p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p>No prescriptions have been created yet.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-dark mb-4">
                <div class="card-header">
                    Common Actions
                </div>

                <div class="card-body">
                    <a asp-page="/Prescriptions/Create" class="btn btn-primary w-100 mb-2">
                        Create Prescription
                    </a>

                    <a asp-page="/CampusEvents/Create" class="btn btn-outline-warning w-100 mb-2">
                        Add Event
                    </a>

                    <a asp-page="/Students/Create" class="btn btn-outline-success w-100 mb-2">
                        Add Student
                    </a>

                    <a asp-page="/StudentCaseNotes/Create" class="btn btn-outline-secondary w-100">
                        Add Case Note
                    </a>
                </div>
            </div>

            <div class="card shadow-sm border-dark">
                <div class="card-header">
                    Backend Status
                </div>

                <div class="card-body">
                    <p><strong>Database:</strong> Connected</p>
                    <p><strong>Events:</strong> Search/filter working</p>
                    <p><strong>Prescriptions:</strong> Saving to database</p>
                    <p><strong>Prototype Status:</strong> Active</p>
                </div>
            </div>
        </div>
    </div>

</div>