@page
@model RazorPagesMovie.Pages.Students.IndexModel

@{
    ViewData["Title"] = "Students";
}

<div class="container mt-4">

    <div class="p-5 mb-4 bg-light rounded-3 border">
        <h1 class="display-5 fw-bold">Students</h1>
        <p class="fs-5">
            View student records used in prescriptions and support cases.
        </p>
    </div>

    <p>
        <a asp-page="Create" class="btn btn-primary">Create New Student</a>
    </p>

    <div class="row">
        @foreach (var item in Model.Student)
        {
            <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-dark">
                    <div class="card-header">
                        <strong>@item.FirstName @item.LastName</strong>
                    </div>

                    <div class="card-body">
                        <p><strong>Email:</strong> @item.Email</p>
                        <p><strong>Student Number:</strong> @item.StudentNumber</p>
                        <p><strong>Status:</strong> @item.Status</p>
                    </div>

                    <div class="card-footer">
                        <a asp-page="./Edit" asp-route-id="@item.StudentId" class="btn btn-outline-secondary btn-sm">Edit</a>
                        <a asp-page="./Details" asp-route-id="@item.StudentId" class="btn btn-outline-info btn-sm">Details</a>
                        <a asp-page="./Delete" asp-route-id="@item.StudentId" class="btn btn-outline-danger btn-sm">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>

</div>