@page
@model RazorPagesMovie.Pages_Prescribers.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Prescriber[0].FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prescriber[0].LastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prescriber[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prescriber[0].Department)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prescriber[0].TrainedStatus)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Prescriber) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Department)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TrainedStatus)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.PrescriberId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.PrescriberId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.PrescriberId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
