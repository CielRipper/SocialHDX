@page
@model RazorPagesMovie.Pages.Prescribers.IndexModel

@{
    ViewData["Title"] = "Prescribers";
}

<h1>Prescribers</h1>

<p>
    <a asp-page="Create">Create New Prescriber</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Department</th>
            <th>Training Completed</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Prescriber) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Department)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TrainedStatus)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.PrescriberId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.PrescriberId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.PrescriberId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
